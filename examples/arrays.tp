use std.io

fn main() {
    println("=== Array Demo ===")

    unsafe {
        let arr:i32* = alloc(12)
        arr[0] = 10
        arr[1] = 20
        arr[2] = 30

        for i in 0..3 {
            println(arr[i])
        }

        let a:i32 = arr[0]
        let b:i32 = arr[1]
        let c:i32 = arr[2]
        let total:i32 = a + b + c
        println("Sum:")
        println(total)

        free(arr)
    }

    println("Done!")
}
