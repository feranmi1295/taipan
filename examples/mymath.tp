fn square(x: f32) -> f32 {
    return x * x
}

fn cube(x: f32) -> f32 {
    return x * x * x
}

fn clamp(x: f32, lo: f32, hi: f32) -> f32 {
    if x < lo {
        return lo
    }
    if x > hi {
        return hi
    }
    return x
}

fn factorial(n: i32) -> i32 {
    if n <= 1 {
        return 1
    }
    return n * factorial(n - 1)
}
